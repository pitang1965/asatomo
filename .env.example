# アサトモ 環境変数のひな型（nafuda と同じ file-per-env 方式・staging なし）。
#
# 環境ごとにファイルを分ける（いずれも .gitignore 済み・コミットしない）:
#   .env.local       … ローカル開発。開発サーバー（vite）・dev スクリプト・db:migrate が読む。
#   .env.production   … 本番。`npm run db:migrate:prod` からのみ参照（本番Workerの実行時値は
#                       wrangler の vars/secrets 側。このファイルはローカルからの本番操作用）。
#
# セットアップ:
#   1. このファイルを .env.local にコピーして開発用の値を入れる（DATABASE_URL は開発DB）。
#   2. 開発DBへ: npm run db:migrate  → npx tsx scripts/seed-dev.ts
#   3. 本番DBへ当てるときだけ: .env.production を用意して npm run db:migrate:prod
#
# DBは本番と開発で必ず分ける（別のNeonブランチ/DBを指す）。dev スクリプトは .env.local しか
# 読まないので、構造的に本番を触らない。

# Neon Postgres（.env.local には開発DB、.env.production には本番DB）
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=（ランダムな長い文字列）
# 開発は Vite の 5173 とオリジン一致が必須（vite.config.ts のメモ参照）。
BETTER_AUTH_URL=http://127.0.0.1:5173

# 見守りWeb の公開URL（通知メールのリンク等）。未設定なら BETTER_AUTH_URL にフォールバック。
# 本番でドメインを変えるときは wrangler.jsonc の BETTER_AUTH_URL を更新すれば連動する。
WEB_BASE_URL=

# ソーシャルログイン（OAuth）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=

# メール送信（Resend）。EMAIL_FROM は検証済みドメイン上のアドレス。未設定なら開発は
# コンソール出力にフォールバック（実送信しない）。
EMAIL_API_KEY=
EMAIL_FROM=no-reply@over40web.club

# 監視tick 縮退時の運営者通報先。
OPERATOR_EMAIL=

# 開発専用の認証バイパス（Authorization: Bearer <secret>:<userId>）。
# ⚠ 本番には絶対に設定しない。Android 実験（OAuth 配線前）用。
DEV_BEARER_SECRET=
