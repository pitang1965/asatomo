{
  "name": "asatomo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:cf": "vite build --config vite.cloudflare.config.ts",
    "deploy": "npm run build:cf && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "drizzle-kit migrate --config drizzle.config.production.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "android:build": "bash scripts/build-android.sh",
    "android:build:release": "bash scripts/build-android.sh release",
    "android:install": "bash scripts/build-android.sh debug --install",
    "android:reinstall": "bash scripts/build-android.sh debug --reinstall"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.28",
    "better-auth": "^1.6.23",
    "drizzle-orm": "latest",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "latest",
    "typescript": "latest",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
